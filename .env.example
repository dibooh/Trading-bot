# ============================================================
# BINANCE API
# ============================================================
# Get from: https://www.binance.com/en/my/settings/api-management
# CRITICAL: Enable ONLY "Spot & Margin Trading" + "Reading"
# DO NOT enable Withdrawals
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Set "true" for testnet (recommended for first run)
USE_TESTNET=false

# ============================================================
# CLAUDE AI (for intelligent decisions)
# ============================================================
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Set "false" to disable Claude AI
CLAUDE_ENABLED=true

# ============================================================
# TELEGRAM (optional)
# ============================================================
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
